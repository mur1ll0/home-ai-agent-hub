{
  "name": "home-ai-agent-hub",
  "version": "3.0.0",
  "description": "Agente pessoal de IA com OpenRouter, LangChain e arquitetura limpa",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS= tsx watch src/main.ts",
    "dev:http": "cross-env NODE_OPTIONS= tsx watch src/main.ts",
    "dev:cli": "cross-env NODE_OPTIONS= APP_MODE=cli tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test:langchain": "node scripts/test-langchain.mjs",
    "dev:langgraph": "langgraphjs dev -c langgraph.json -p 2025",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agent",
    "openrouter",
    "langchain",
    "clean-architecture",
    "solid"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.3.12",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.1",
    "@langchain/core": "^0.3.52",
    "@langchain/openai": "^0.6.12",
    "@modelcontextprotocol/sdk": "^1.12.3",
    "csv-stringify": "^6.5.2",
    "docx": "^9.5.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.3.3",
    "langchain": "^0.3.30",
    "playwright": "^1.54.2",
    "pptxgenjs": "^3.12.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@langchain/langgraph-cli": "0.0.40",
    "@types/node": "^24.3.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.33.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.2.4"
  }
}
